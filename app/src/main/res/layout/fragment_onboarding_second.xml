<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDD0"
    android:padding="24dp"
    tools:context=".OnboardingSecondFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_proximo_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/img_ilustracao_2"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:src="@drawable/imagem_2"
            android:contentDescription="Ilustração do mapa" />

        <TextView
            android:id="@+id/txt_titulo_onboarding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conheça seu Bairro"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#3C3C6C"
            android:layout_marginTop="32dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/txt_descricao_onboarding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifique a presença de registros de\nagressão sexual na sua região (com\nbase em dados públicos)"
            android:textSize="16sp"
            android:textColor="#3C3C6C"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_proximo_2"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Próximo"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#8285C7"
        android:insetBottom="0dp"
        android:insetTop="0dp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="72dp" />

</androidx.constraintlayout.widget.ConstraintLayout>